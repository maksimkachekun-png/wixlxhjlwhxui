def parse_token_json(data: dict) -> dict:
    token = data.get("token", "")
    device_id = data.get("deviceId", str(uuid.uuid4()))
    password = data.get("password", "")
    
    user = data.get("user", {})
    phone = str(user.get("phone", "unknown"))
    if phone != "unknown":
        phone = f"+{phone}"
    
    return {
        "token": token,
        "device_id": device_id,
        "phone": phone,
        "password": password
    }

def add_account_from_json(data: dict) -> bool:
    parsed = parse_token_json(data)
    token = parsed["token"]
    
    if not token or len(token) < 20:
        logging.warning(f"[DATA] Skipped invalid token: {str(data)[:100]}")
        return False
    
    acc_id = str(uuid.uuid4())[:8]
    accounts[acc_id] = {
        "token": token,
        "device_id": parsed["device_id"],
        "phone": parsed["phone"],
        "password": parsed["password"],
        "added_at": time.time(),
        "total_scans": 0
    }
    logging.info(f"[DATA] Added account: {parsed['phone']} (id={acc_id})")
    return True

def process_content(content: str) -> tuple:
    added = 0
    skipped = 0
    
    # ===== ФОРМАТ 1: Чистый JSON (массив или объект) =====
    try:
        data = json.loads(content)
        
        if isinstance(data, list):
            for item in data:
                if isinstance(item, dict):
                    if add_account_from_json(item):
                        added += 1
                    else:
                        skipped += 1
            return added, skipped
        elif isinstance(data, dict):
            if add_account_from_json(data):
                added += 1
            else:
                skipped += 1
            return added, skipped
    except:
        pass
    
    # ===== ФОРМАТ 2: token {JSON} shortcode + const customPayload = "xxxxx" =====
    pattern1 = r'([A-Za-z0-9_\-]{100,})\s*(\{[^}]+\})\s*([A-Za-z0-9_\-]{5,30})'
    matches = re.findall(pattern1, content)
    
    if matches:
        for match in matches:
            token = match[0]
            try:
                device_info = json.loads(match[1])
                short_code = match[2]
                
                device_id = device_info.get("deviceId", str(uuid.uuid4()))
                device_name = device_info.get("deviceName", "unknown")
                
                acc_id = str(uuid.uuid4())[:8]
                accounts[acc_id] = {
                    "token": token,
                    "device_id": device_id,
                    "phone": f"{device_name}_{short_code}",
                    "password": "",
                    "added_at": time.time(),
                    "total_scans": 0
                }
                added += 1
                logging.info(f"[PARSE] Added token: {device_name} ({acc_id})")
            except Exception as e:
                logging.error(f"[PARSE] Error parsing regex match: {e}")
                skipped += 1
        
        # Ищем customPayload
        pattern2 = r'const\s+customPayload\s*=\s*"(\d+)"'
        custom_matches = re.findall(pattern2, content)
        if custom_matches and added > 0:
            custom_payload = custom_matches[0]
            last_acc_id = list(accounts.keys())[-1]
            accounts[last_acc_id]["password"] = custom_payload
            logging.info(f"[PARSE] Added customPayload as password: {custom_payload}")
        
        return added, skipped
    
    # ===== ФОРМАТ 3: Построчный парсинг =====
    lines = content.strip().split('\n')
    
    # Сначала собираем customPayload если есть
    custom_payload = None
    for line in lines:
        custom_match = re.search(r'const\s+customPayload\s*=\s*"(\d+)"', line)
        if custom_match:
            custom_payload = custom_match.group(1)
            break
    
    i = 0
    while i < len(lines):
        line = lines[i].strip()
        
        # Пропускаем пустые строки и customPayload
        if not line or line.startswith('const customPayload'):
            i += 1
            continue
        
        # ===== Пробуем JSON строку =====
        try:
            data = json.loads(line)
            if isinstance(data, dict):
                if add_account_from_json(data):
                    added += 1
                else:
                    skipped += 1
                i += 1
                continue
        except:
            pass
        
        # ===== Пробуем формат token|device_id|phone =====
        if '|' in line:
            parts = line.split('|')
            token = parts[0].strip() if len(parts) > 0 else ""
            if token and len(token) >= 20:
                device_id = parts[1].strip() if len(parts) > 1 else str(uuid.uuid4())
                phone = parts[2].strip() if len(parts) > 2 else "unknown"
                
                acc_id = str(uuid.uuid4())[:8]
                accounts[acc_id] = {
                    "token": token,
                    "device_id": device_id,
                    "phone": phone,
                    "password": custom_payload or "",
                    "added_at": time.time(),
                    "total_scans": 0
                }
                added += 1
                i += 1
                continue
        
        # ===== Пробуем длинный токен (одна строка) =====
        if len(line) > 100 and not line.startswith('{') and not line.startswith('const'):
            token = line.split()[0] if ' ' in line else line
            if len(token) >= 20:
                acc_id = str(uuid.uuid4())[:8]
                accounts[acc_id] = {
                    "token": token,
                    "device_id": str(uuid.uuid4()),
                    "phone": "unknown",
                    "password": custom_payload or "",
                    "added_at": time.time(),
                    "total_scans": 0
                }
                added += 1
                i += 1
                continue
        
        # ===== Пробуем формат token device_id phone (через пробел) =====
        parts = line.split()
        if len(parts) >= 1:
            token = parts[0]
            if len(token) >= 20:
                device_id = parts[1] if len(parts) > 1 and len(parts[1]) > 10 else str(uuid.uuid4())
                phone = parts[2] if len(parts) > 2 else "unknown"
                
                acc_id = str(uuid.uuid4())[:8]
                accounts[acc_id] = {
                    "token": token,
                    "device_id": device_id,
                    "phone": phone,
                    "password": custom_payload or "",
                    "added_at": time.time(),
                    "total_scans": 0
                }
                added += 1
                i += 1
                continue
        
        skipped += 1
        i += 1
    
    return added, skipped

