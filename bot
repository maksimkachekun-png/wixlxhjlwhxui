@dp.message(AuthState.waiting_for_qr, F.photo)
async def handle_qr_photo(message: types.Message, state: FSMContext):
    msg = await message.answer("⏳ Распознаю QR-код...")
    logging.info(f"[QR] Photo received from {message.from_user.id}")
    
    try:
        photo = message.photo[-1]
        file = await bot.get_file(photo.file_id)
        file_bytes = await bot.download_file(file.file_path)
        
        files = {'file': ('qr.png', file_bytes.read())}
        
        response = requests.post(
            'https://api.qrserver.com/v1/read-qr-code/',
            files=files,
            timeout=10
        )
        
        qr_data = None
        try:
            data = response.json()
            logging.info(f"[QR] API response: {data}")
            if data and isinstance(data, list) and len(data) > 0:
                symbol = data[0].get("symbol", [])
                if symbol and len(symbol) > 0:
                    qr_data = symbol[0].get("data", "")
        except:
            pass
        
        if not qr_data:
            logging.info("[QR] Trying goqr.me API...")
            response = requests.post(
                'https://api.goqr.me/read-qr-code/',
                files=files,
                timeout=10
            )
            try:
                data = response.json()
                logging.info(f"[QR] goqr response: {data}")
                if data and isinstance(data, list) and len(data) > 0:
                    qr_data = data[0].get("data", "")
            except:
                pass
        
        if qr_data:
            logging.info(f"[QR] Decoded data: {qr_data}")
            await process_qr(message, state, qr_data, msg)
            return
        
        logging.warning("[QR] Both APIs failed")
        await msg.edit_text("❌ QR-код не найден на фото. Попробуйте другое фото с чётким QR-кодом.")
        
    except Exception as e:
        logging.error(f"[QR] Error: {e}")
        await msg.edit_text(f"❌ Ошибка распознавания: {e}")

async def process_qr(message: types.Message, state: FSMContext, qr_input: str, msg):
    logging.info(f"[QR] Processing: {qr_input}")
    qr_link = qr_input
    track_id = None
    
    if "web.max.ru/link/" in qr_input:
        try:
            track_id = qr_input.split("/link/")[1].split("?")[0]
            logging.info(f"[QR] Extracted track_id from web.max.ru: {track_id}")
        except:
            pass
    
    if not track_id and "/:auth/" in qr_input:
        try:
            track_id = qr_input.split("/:auth/")[1].split("?")[0]
            logging.info(f"[QR] Extracted track_id from :auth: {track_id}")
        except:
            pass
    
    if not track_id and "link/" in qr_input.lower():
        try:
            parts = qr_input.split("link/")
            if len(parts) > 1:
                track_id = parts[1].split("?")[0].split("/")[0]
                logging.info(f"[QR] Extracted track_id from link: {track_id}")
        except:
            pass
    
    if not track_id:
        logging.error(f"[QR] Failed to extract track_id from: {qr_input}")
        await msg.edit_text(f"❌ Не удалось извлечь ID из QR.\n\nДанные QR: <code>{qr_input[:200]}</code>", parse_mode="HTML")
        return
    
    acc_ids = list(accounts.keys())
    if not acc_ids:
        await msg.edit_text("❌ Нет доступных аккаунтов")
        await state.clear()
        return
    
    acc_id = acc_ids[0]
    acc = accounts[acc_id]
    
    await msg.edit_text(f"⏳ Сканирую QR через {acc['phone']}...")
    logging.info(f"[QR] Using account: {acc['phone']}")
    
    scanner = QRScanner(acc["token"], acc["device_id"])
    
    result = None
    def do_scan():
        nonlocal result
        result = scanner.scan(track_id, qr_link)
    
    threading.Thread(target=do_scan, daemon=True).start()
    
    for _ in range(30):
        if result: break
        await asyncio.sleep(0.5)
    
    logging.info(f"[QR] Scan result: {result}")
    
    if result is None:
        await msg.edit_text("❌ Таймаут сканирования")
    elif result.get("success"):
        pwd = acc.get("password", "")
        if pwd:
            text = (
                f"✅ QR-code успешно отсканирован!\n\n"
                f"🔐 На аккаунте установлен пароль.\n"
                f"<b>Пароль от аккаунта:</b> <code>{pwd}</code>"
            )
        else:
            text = (
                f"✅ QR-code успешно отсканирован!\n\n"
                f"🔓 Пароль на аккаунте отсутствует."
            )
        
        # Удаляем аккаунт после использования
        del accounts[acc_id]
        save_accounts()
        
        await msg.edit_text(text, parse_mode="HTML")
    elif result.get("password_challenge"):
        pwd = acc.get("password", "")
        if pwd:
            await msg.edit_text(
                f"🔐 Аккаунт {acc['phone']} защищён паролем 2FA.\n\n"
                f"<b>Пароль:</b> <code>{pwd}</code>",
                parse_mode="HTML"
            )
        else:
            await msg.edit_text(f"🔐 Аккаунт {acc['phone']} защищён паролем 2FA, но пароль не найден в базе.")
        
        # Удаляем аккаунт
        del accounts[acc_id]
        save_accounts()
    else:
        await msg.edit_text(f"❌ Ошибка: {result.get('error', 'неизвестно')}")
    
    await state.clear()

async def main():
    logging.info("QR Scanner Bot запущен!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
